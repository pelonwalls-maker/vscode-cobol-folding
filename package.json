{
	"name": "cobol-folding",
	"displayName": "COBOL Folding",
	"description": "Add foldings to COBOL files",
	"version": "0.3.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"publisher": "zokugun",
	"license": "MIT",
	"homepage": "https://github.com/zokugun/vscode-cobol-folding",
	"repository": {
		"type": "git",
		"url": "https://github.com/zokugun/vscode-cobol-folding.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/vscode-cobol-folding/issues"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"main": "./lib/index.js",
	"browser": "./lib/index.js",
	"scripts": {
		"bundle": "webpack",
		"commit": "cz",
		"compile": "tsc -p .",
		"lint": "xo",
		"package": "node -e \"require('fs').readdirSync('.').filter(f=>f.endsWith('.vsix')).forEach(f=>require('fs').unlinkSync(f))\" && vsce package",
		"prepare": "husky install; fixpack || true",
		"release": "release-it",
		"build": "npm run compile && npm run bundle",
		"vscode:prepublish": "npm run compile && npm run bundle",
		"watch": "tsc-watch -p tsconfig.json --onSuccess \"npm run bundle\""
	},
	"devDependencies": {
		"@commitlint/cli": "^17.0.3",
		"@commitlint/config-conventional": "^17.0.3",
		"@types/node": "^18.0.0",
		"@types/vscode": "^1.74.0",
		"commitizen": "^4.3.1",
		"fixpack": "^4.0.0",
		"husky": "^8.0.1",
		"lint-staged": "^13.0.3",
		"path-browserify": "^1.0.1",
		"process": "^0.11.10",
		"release-it": "^19.0.5",
		"tsc-watch": "^6.0.0",
		"typescript": "^5.0.0",
		"webpack": "^5.80.0",
		"webpack-cli": "^5.0.0",
		"xo": "^0.60.0"
	},
	"activationEvents": [
		"onLanguage:cobol",
		"onLanguage:gnucobol",
		"onLanguage:COBOL"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "COBOL Folding configuration",
			"properties": {
				"cobolFolding.enabled": {
					"type": "boolean",
					"default": true,
					"description": ""
				}
			}
		}
	},
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#373b41",
		"theme": "dark"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"cobol",
		"folding"
	],
	"extensionKind": [
		"ui",
		"workspace"
	]
}
